{
  "name": "ai-preflight",
  "displayName": "AI Preflight",
  "description": "Context observability and optimization for AI-assisted development. See what context your AI tools are using, estimate prompt size, and get suggestions to improve AI responses.",
  "version": "0.1.3",
  "publisher": "KiranChanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deepwissen/ai-preflight.git"
  },
  "bugs": {
    "url": "https://github.com/deepwissen/ai-preflight/issues"
  },
  "homepage": "https://github.com/deepwissen/ai-preflight#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "context",
    "tokens",
    "observability",
    "prompt",
    "preflight"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-preflight",
          "title": "AI Preflight",
          "icon": "$(search-fuzzy)"
        }
      ]
    },
    "views": {
      "ai-preflight": [
        {
          "type": "webview",
          "id": "ai-preflight.panel",
          "name": "AI Preflight"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-preflight.analyze",
        "title": "AI Preflight: Analyze Context"
      },
      {
        "command": "ai-preflight.togglePanel",
        "title": "AI Preflight: Toggle Panel"
      },
      {
        "command": "ai-preflight.exportContext",
        "title": "AI Preflight: Export Context to Clipboard"
      }
    ],
    "keybindings": [
      {
        "command": "ai-preflight.togglePanel",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "chatParticipants": [
      {
        "id": "ai-preflight.preflight",
        "name": "preflight",
        "fullName": "AI Preflight",
        "description": "Analyze your IDE context before prompting. See risk level, token usage, waste patterns, and suggestions.",
        "isSticky": false
      }
    ],
    "configuration": {
      "title": "AI Preflight",
      "properties": {
        "ai-preflight.aiTool": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "claude-code",
            "cursor",
            "copilot",
            "windsurf",
            "amazon-q",
            "gemini",
            "chatgpt"
          ],
          "enumDescriptions": [
            "Auto-detect from installed extensions and workspace files",
            "Claude Code (Anthropic CLI)",
            "Cursor (AI-native editor)",
            "GitHub Copilot",
            "Windsurf (Codeium)",
            "Amazon Q Developer",
            "Google Gemini",
            "ChatGPT (copy-paste workflow)"
          ],
          "description": "Your primary AI coding tool. Used for context window limits, instruction file suggestions, and tool-specific warnings."
        },
        "ai-preflight.aiModel": {
          "type": "string",
          "default": "",
          "description": "Optional: specific model within your AI tool (e.g., 'gpt-4o' for Copilot, 'gemini' for Copilot). Leave empty to use the tool's default context window."
        }
      }
    }
  },
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs --production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "preact": "^10.19.0"
  }
}
